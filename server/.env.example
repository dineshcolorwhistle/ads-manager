# Database (use local MongoDB below, or your Atlas URI; if using Atlas, add your IP to Network Access)
MONGO_URI=mongodb://localhost:27017/ad_campaign_system

# Server
PORT=5000
NODE_ENV=development

# Logging
LOG_LEVEL=info

# Public API Key (for public automation endpoints)
PUBLIC_API_KEY=change_me_to_a_long_random_value

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=7d

# Encryption (32 bytes = 64 hex characters)
MASTER_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Google Ads OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/platforms/google/callback

# Meta Ads OAuth
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_CALLBACK_URL=http://localhost:5000/api/platforms/meta/callback
